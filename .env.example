# twitterapi.io API Key
TWITTER_API_KEY=your_twitterapi_io_key_here

# Anthropic API Key (for Claude Haiku summarization)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Service Account JSON (paste entire JSON as single line)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Google Spreadsheet ID (from the sheet URL)
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Twitter username (without @)
TWITTER_USERNAME=garyintern
